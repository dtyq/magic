{
  "name": "@magic-web/pdf-export",
  "version": "0.1.0",
  "private": false,
  "description": "Browser-based PDF export utilities",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm exec vite build --config ./vite.config.ts --mode production && pnpm run build:types",
    "build:types": "tsc -p ./tsconfig.build.json --emitDeclarationOnly",
    "dev": "pnpm exec vite --config ./vite.config.ts",
    "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build",
    "preview": "pnpm exec vite preview --config ./vite.config.ts --mode production",
    "test": "pnpm exec vitest run --config ./vitest.config.ts",
    "test:watch": "pnpm exec vitest --config ./vitest.config.ts",
    "typecheck": "tsc -p ./tsconfig.json --noEmit"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@zumer/snapdom": "^2.0.2",
    "jspdf": "^2.5.2",
    "typescript": "^5.4.5",
    "vite": "^8.0.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@zumer/snapdom": "^2.0.2",
    "jspdf": "^2.5.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
