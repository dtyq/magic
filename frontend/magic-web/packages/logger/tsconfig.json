{
	"compilerOptions": {
		"target": "ES2020",
		"lib": ["ES2020", "DOM"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"allowImportingTsExtensions": true,
		"declaration": true,
		"declarationMap": false,
		"outDir": "dist",
		"rootDir": "src",
		"types": ["node"]
	},
	"include": ["src/**/*"],
	"exclude": ["dist", "node_modules"]
}
