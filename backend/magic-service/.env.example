APP_NAME=magic_service
APP_ENV=dev
APP_HOST=http://magic-service:9501
APP_WS_HOST=

OFFICE_ORGANIZATION=Magic
OFFICE_ORGANIZATION_NAME='{"zh_CN":"官方组织","en_US":"Official Organization"}'

# IPC Go Engine auto-start (for local `make dev`)
# IPC_ENGINE_AUTO_START=true
# IPC_ENGINE_START_COMMAND="CONFIG_FILE=./magic-go-engine-config.yaml ./bin/magic-go-engine"
# IPC_ENGINE_WORKDIR=/absolute/path/to/backend/magic-service
# IPC_ENGINE_SOCKET=/absolute/path/to/backend/magic-service/runtime/magic_engine.sock
# IPC_PHP_SOCKET=/absolute/path/to/backend/magic-service/runtime/magic_php.sock
# IPC_PROTOCOL_VERSION=1
# IPC_AUTH_TOKEN=
# IPC_MAX_MESSAGE_BYTES=10485760
# IPC_READ_TIMEOUT=30
# IPC_WRITE_TIMEOUT=10
# IPC_HEARTBEAT_INTERVAL=10
# IPC_HEARTBEAT_TIMEOUT=30
# IPC_MAX_PENDING_REQUESTS=1024
# IPC_DISCARD_CAP_MULTIPLIER=4
# IPC_DISCARD_CHUNK_SIZE=32768
# IPC_DISCARD_TIMEOUT=0
# IPC_OVERSIZE_MAX_BURST=3

MAGIC_API_DEFAULT_ACCESS_TOKEN=
MAGIC_PRIVILEGED_PASSWORD=

CHAT_MODEL_FALLBACK_CHAIN=["gpt-4o","gpt-4.1","deepseek-v3"]

# Super admin permission configuration
SUPER_WHITELISTS={"privilege_send_message":["13800000000","13900000000"]}
# Organization management backend permission whitelist
ORGANIZATION_WHITELISTS={}
# Fallback organization admin permission from magic_organization_admins when RBAC role relations are missing
ENABLE_ORGANIZATION_ADMIN_PERMISSION_FALLBACK=false

## Chat quality assurance
ENABLE_CONSUME=true
ENABLE_CHAT_MESSAGE=true
ENABLE_CHAT_SEQ=true

# Enable Magic Watchdog (can be disabled for local development)
ENABLE_MAGIC_WATCHDOG=false

# Mysql
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=

# Redis
REDIS_HOST=localhost
REDIS_AUTH=(null)
REDIS_PORT=6379
REDIS_DB=0

# RabbitMQ Configuration
AMQP_HOST=rabbitmq
AMQP_PORT=5672
AMQP_USER=
AMQP_PASSWORD=
AMQP_VHOST=

# File Driver
FILE_DRIVER=local

# 本地文件驱动配置
FILE_LOCAL_ROOT=
FILE_LOCAL_READ_HOST=http://127.0.0.1/files
FILE_LOCAL_WRITE_HOST=http://127.0.0.1
FILE_LOCAL_DOCKER_READ_HOST=http://magic-caddy/files
FILE_LOCAL_DOCKER_WRITE_HOST=http://magic-service:9501/api/v1/file/upload

# Aliyun OSS File Driver Configuration - Private
FILE_PRIVATE_ALIYUN_ACCESS_ID=
FILE_PRIVATE_ALIYUN_ACCESS_SECRET=
FILE_PRIVATE_ALIYUN_BUCKET=
FILE_PRIVATE_ALIYUN_ENDPOINT=
FILE_PRIVATE_ALIYUN_ROLE_ARN=

# Aliyun OSS File Driver Configuration - Public
FILE_PUBLIC_ALIYUN_ACCESS_ID=
FILE_PUBLIC_ALIYUN_ACCESS_SECRET=
FILE_PUBLIC_ALIYUN_BUCKET=
FILE_PUBLIC_ALIYUN_ENDPOINT=
FILE_PUBLIC_ALIYUN_ROLE_ARN=

# Aliyun OSS File Driver Configuration - SandBox
FILE_SANDBOX_ALIYUN_ACCESS_ID=
FILE_SANDBOX_ALIYUN_ACCESS_SECRET=
FILE_SANDBOX_ALIYUN_BUCKET=
FILE_SANDBOX_ALIYUN_ENDPOINT=
FILE_SANDBOX_ALIYUN_ROLE_ARN=

# Volc Engine TOS File Driver Configuration - Private
FILE_PRIVATE_TOS_AK=
FILE_PRIVATE_TOS_SK=
FILE_PRIVATE_TOS_BUCKET=
FILE_PRIVATE_TOS_ENDPOINT=
FILE_PRIVATE_TOS_REGION=
FILE_PRIVATE_TOS_ROLE_ARN=

# Volc Engine TOS File Driver Configuration - Public
FILE_PUBLIC_TOS_AK=
FILE_PUBLIC_TOS_SK=
FILE_PUBLIC_TOS_BUCKET=
FILE_PUBLIC_TOS_ENDPOINT=
FILE_PUBLIC_TOS_REGION=
FILE_PUBLIC_TOS_ROLE_ARN=

# Volc Engine TOS File Driver Configuration - SandBox
FILE_SANDBOX_TOS_AK=
FILE_SANDBOX_TOS_SK=
FILE_SANDBOX_TOS_BUCKET=
FILE_SANDBOX_TOS_ENDPOINT=
FILE_SANDBOX_TOS_REGION=
FILE_SANDBOX_TOS_TRN=

# Proxy required for Google search
HTTP_PROXY=
GOOGLE_SEARCH_API_KEY=
# If using Google, please specify the search cx (GOOGLE_SEARCH_ENGINE_ID)
GOOGLE_SEARCH_CX=
BACKEND=GOOGLE
RELATED_QUESTIONS=true

AZURE_OPENAI_4_API_KEY=
AZURE_OPENAI_4_API_BASE=
AZURE_OPENAI_4_API_VERSION=2023-08-01-preview
AZURE_OPENAI_4_DEPLOYMENT_NAME=

AZURE_OPENAI_35_TURBO_API_KEY=
AZURE_OPENAI_35_TURBO_API_BASE=
AZURE_OPENAI_35_TURBO_API_VERSION=2023-08-01-preview
AZURE_OPENAI_35_TURBO_DEPLOYMENT_NAME=

# App
APP_ID=
APP_SECRET=
APP_CODE=

# Qdrant
ODIN_QDRANT_BASE_URI=
ODIN_QDRANT_API_KEY=
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_TARGET_SPARSE_BACKEND=client_bm25_qdrant_idf_v1
QDRANT_MAX_CONCURRENT_WRITES=4
QDRANT_LOG_TIMING_ENABLED=true
QDRANT_LOG_SLOW_THRESHOLD_MS=100

# Go engine shared runtime
MYSQL_PARAMS=parseTime=true&multiStatements=true
DB_LOG_SQL=true
REDIS_USERNAME=
REDIS_LOCK_PREFIX=magic_lock:
KNOWLEDGE_REBUILD_MAX_CONCURRENCY=8
MAGIC_MODEL_GATEWAY_BASE_URL=http://localhost:8080
MAGIC_ACCESS_TOKEN=
EMBEDDING_DIMENSION=1536
EMBEDDING_CLIENT_TYPE=php
EMBEDDING_MIN_INTERVAL_SECONDS=1
EMBEDDING_MIN_EVENTS_BETWEEN=10
EMBEDDING_CACHE_AUTO_CLEANUP_ENABLED=true
EMBEDDING_CACHE_CLEANUP_INTERVAL_HOURS=24
EMBEDDING_CACHE_CLEANUP_TIMEOUT_MINUTES=30
EMBEDDING_CACHE_MIN_ACCESS_COUNT=2
EMBEDDING_CACHE_MAX_IDLE_DURATION_HOURS=720
EMBEDDING_CACHE_MAX_CACHE_AGE_HOURS=2160
EMBEDDING_CACHE_BATCH_SIZE=1000
RABBITMQ_EMBEDDING_QUEUE=embedding_jobs
LOG_LEVEL=debug
LOG_FORMAT=magic
SERVER_ENABLED=false
SERVER_HOST=localhost
SERVER_PORT=81
SERVER_MODE=debug
SERVER_PPROF_ENABLED=false
VOLCENGINE_OCR_PDF_AK=
VOLCENGINE_OCR_PDF_SK=
VOLC_ENDPOINT=
VOLC_REGION=

# CODE whitelist
CODE_WHITE_ACCOUNT_ID=

# Default magic_environment id
DEFAULT_MAGIC_ENVIRONMENT_ID=

# Magic environment id
MAGIC_ENV_ID=10000

# HD conversion
MIRACLE_VISION_KEY=
MIRACLE_VISION_SECRET=

# SUPER MAGIC
SANDBOX_GATEWAY=
SANDBOX_TOKEN=
SANDBOX_MESSAGE_MODE=
SHARE_ENCRYPT_KEY=
SHARE_ENCRYPT_IV=
