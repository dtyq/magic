{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@dtyq/x-markdown": ["./src/index.ts"],
      "@dtyq/x-markdown/es/*": ["./src/*"],
      "@dtyq/x-markdown/lib/*": ["./src/*"]
    }
  },
  "include": ["src", "scripts", ".fatherrc.ts"],
  "exclude": ["node_modules", "dist", "es", "lib", "**/__tests__/**", "**/__benchmark__/**"]
}
