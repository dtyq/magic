{
	"name": "@dtyq/x-markdown",
	"version": "1.0.0",
	"scripts": {
		"compile": "father build",
		"tsc": "tsc --noEmit",
		"precompile": "npm run version",
		"version": "tsx scripts/generate-version.ts",
		"clean": "rm -rf es lib dist plugins themes"
	},
	"sideEffects": [
		"**/*.css"
	],
	"main": "lib/index.js",
	"module": "es/index.js",
	"typings": "es/index.d.ts",
	"files": [
		"dist",
		"es",
		"lib",
		"plugins",
		"themes"
	],
	"keywords": [
		"AI",
		"markdown",
		"streaming",
		"react"
	],
	"license": "MIT",
	"description": "Streaming-friendly and extensible Markdown renderer for React.",
	"dependencies": {
		"clsx": "^2.1.1",
		"dompurify": "^3.2.6",
		"html-react-parser": "^5.2.13",
		"katex": "^0.16.22",
		"marked": "^15.0.12"
	},
	"devDependencies": {
		"@types/dompurify": "^3.0.5",
		"@types/node": "^22.16.4",
		"@types/react": "^19.0.2",
		"@types/react-dom": "^19.0.2",
		"father": "^4.5.0",
		"tsx": "^4.21.0",
		"typescript": "^5.4.5"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0"
	}
}
