{
	"name": "@dtyq/magic-admin",
	"version": "0.1.6",
	"description": "React admin module package with views, routes, and provider for host app integration.",
	"keywords": [
		"react",
		"admin",
		"routing",
		"micro-frontend",
		"component-library"
	],
	"homepage": "https://github.com/dtyq/magic/tree/master/frontend/magic-admin#readme",
	"bugs": {
		"url": "https://github.com/dtyq/magic/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dtyq/magic.git",
		"directory": "frontend/magic-admin"
	},
	"license": "Apache License 2.0",
	"sideEffects": [
		"**/*.css",
		"**/*.less",
		"src/index.css",
		"src/styles/**/*.css"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./types/src/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.js"
		},
		"./components": {
			"types": "./types/components/index.d.ts",
			"import": "./dist/components/index.js"
		},
		"./capability": {
			"types": "./types/src/pages/CapabilityManage/index.d.ts",
			"import": "./dist/src/pages/CapabilityManage/index.js"
		},
		"./provider": {
			"types": "./types/src/provider/AdminProvider/index.d.ts",
			"import": "./dist/src/provider/AdminProvider/index.js"
		},
		"./ServiceIcon": {
			"types": "./types/src/pages/PlatformPackage/components/ServiceIcon/index.d.ts",
			"import": "./dist/src/pages/PlatformPackage/components/ServiceIcon/index.js"
		}
	},
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "types/src/index.d.ts",
	"typesVersions": {
		"*": {
			"components": [
				"./types/components/index.d.ts"
			],
			"capability": [
				"./types/src/pages/CapabilityManage/index.d.ts"
			],
			"provider": [
				"./types/src/provider/AdminProvider/index.d.ts"
			],
			"ServiceIcon": [
				"./types/src/pages/PlatformPackage/components/ServiceIcon/index.d.ts"
			]
		}
	},
	"files": [
		"dist",
		"types",
		"CHANGELOG.md",
		"README.md",
		"package.json",
		"LICENSE"
	],
	"scripts": {
		"build": "pnpm types && vite build",
		"dev": "vite",
		"lint": "eslint --config .eslintrc.cjs 'src/**/*.{js,ts,tsx}'",
		"prepare": "husky",
		"preview": "vite preview",
		"semantic-release": "semantic-release",
		"semantic-release:preview": "semantic-release --dry-run --no-ci",
		"types": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.json": [
			"prettier --write"
		]
	},
	"devDependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/modifiers": "^9.0.0",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@dtyq/eslint-config": "~0.0.10",
		"@dtyq/upload-sdk": "~0.0.9",
		"@dtyq/user-selector": "^0.1.5",
		"@tabler/icons-react": "^3.38.0",
		"@types/lodash-es": "^4.17.12",
		"@types/node": "^25.0.10",
		"@types/react": "^18.3.2",
		"@types/react-dom": "^18.3.0",
		"@vitejs/plugin-react": "^4.3.4",
		"ahooks": "^3.8.4",
		"antd": "^5.28.0",
		"antd-mobile": "^5.42.3",
		"antd-style": "^3.7.1",
		"axios": "^1.8.4",
		"dayjs": "^1.11.13",
		"husky": "^9.1.7",
		"i18next": "^24.2.2",
		"i18next-resources-to-backend": "^1.2.1",
		"less": "^4.3.0",
		"libphonenumber-js": "^1.12.7",
		"lint-staged": "^15.4.3",
		"lodash-es": "^4.17.21",
		"nanoid": "^5.1.6",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-i18next": "^15.4.1",
		"react-infinite-scroll-component": "^6.1.0",
		"react-router": "^7.5.1",
		"react-router-dom": "^7.5.1",
		"tsc-alias": "^1.8.16",
		"typescript": "~5.7.2",
		"use-immer": "^0.11.0",
		"vite": "^6.1.0",
		"vite-plugin-dts": "^4.5.0",
		"vite-plugin-mkcert": "^1.17.7",
		"zustand": "^4.5.2"
	},
	"peerDependencies": {
		"@dnd-kit/core": ">= 6.0.0",
		"@dnd-kit/modifiers": ">= 9.0.0",
		"@dnd-kit/sortable": ">= 10.0.0",
		"@dnd-kit/utilities": ">= 3.0.0",
		"@dtyq/upload-sdk": ">= 0.0.9",
		"@tabler/icons-react": ">= 3.38.0",
		"ahooks": ">= 3.0.0",
		"antd": ">= 5.0.0",
		"antd-mobile": ">= 5.0.0",
		"antd-style": ">= 3.0.0",
		"axios": ">= 1.0.0",
		"dayjs": ">= 1.11.0",
		"i18next": ">= 23.0.0",
		"libphonenumber-js": ">= 1.12.7",
		"lodash-es": ">= 4.17.0",
		"nanoid": ">= 5.1.5",
		"react": ">= 17.0.0",
		"react-dom": ">= 17.0.0",
		"react-i18next": ">= 13.0.0",
		"react-infinite-scroll-component": ">= 6.0.0",
		"react-router": ">= 6.0.0",
		"react-router-dom": ">= 6.0.0",
		"use-immer": ">= 0.11.0",
		"zustand": ">= 4.0.0"
	},
	"peerDependenciesMeta": {
		"@dnd-kit/core": {
			"optional": true
		},
		"@dnd-kit/modifiers": {
			"optional": true
		},
		"@dnd-kit/sortable": {
			"optional": true
		},
		"@dnd-kit/utilities": {
			"optional": true
		},
		"@dtyq/upload-sdk": {
			"optional": true
		},
		"axios": {
			"optional": true
		},
		"i18next": {
			"optional": true
		},
		"libphonenumber-js": {
			"optional": true
		},
		"nanoid": {
			"optional": true
		},
		"react-i18next": {
			"optional": true
		},
		"react-infinite-scroll-component": {
			"optional": true
		},
		"react-router": {
			"optional": true
		},
		"react-router-dom": {
			"optional": true
		},
		"use-immer": {
			"optional": true
		},
		"zustand": {
			"optional": true
		}
	},
	"packageManager": "pnpm@9.0.0",
	"engines": {
		"node": ">=20.0.0",
		"pnpm": ">=9.0.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
